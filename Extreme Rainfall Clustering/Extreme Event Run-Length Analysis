import os
import numpy as np
import pandas as pd

def run_length_analysis(folder_path):
    rain_series = []

    for file in sorted(os.listdir(folder_path)):
        if file.endswith(".csv"):
            try:
                data = pd.read_csv(
                    os.path.join(folder_path, file),
                    usecols=["precipitationCal"],
                    on_bad_lines="skip",
                    engine="python"
                ).values.flatten()

                rain_series.append(np.mean(data))
            except Exception:
                continue

    rain = np.array(rain_series)

    threshold = np.percentile(rain, 90)
    binary = (rain > threshold).astype(int)

    run_lengths = []
    count = 0

    for val in binary:
        if val == 1:
            count += 1
        else:
            if count > 0:
                run_lengths.append(count)
                count = 0

    return {
        "Average_Run_Length": np.mean(run_lengths) if len(run_lengths) > 0 else 0,
        "Max_Run_Length": np.max(run_lengths) if len(run_lengths) > 0 else 0,
        "Num_Events": len(run_lengths)
    }


if __name__ == "__main__":
    results = run_length_analysis("path_to_year_folder")
    print(results)
