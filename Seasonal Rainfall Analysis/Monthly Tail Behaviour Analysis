import os
import numpy as np
import pandas as pd
from scipy.stats import lognorm

def monthly_tail_analysis(main_folder, threshold=0.1):
    results = []

    for year in sorted(os.listdir(main_folder)):
        year_path = os.path.join(main_folder, year)

        if not (os.path.isdir(year_path) and year.startswith("kcsv")):
            continue

        monthly_data = {i: [] for i in range(1, 13)}

        for file in os.listdir(year_path):
            if file.endswith(".csv"):
                file_path = os.path.join(year_path, file)

                try:
                    df = pd.read_csv(file_path, usecols=["time", "precipitationCal"])
                    month = pd.to_datetime(df["time"].iloc[0]).month

                    rain = df["precipitationCal"].values
                    rain = rain[rain > threshold]

                    if len(rain) > 0:
                        monthly_data[month].extend(rain)
                except Exception:
                    continue

        for month in range(1, 13):
            rain = np.array(monthly_data[month])

            if len(rain) < 100:
                continue

            shape, loc, scale = lognorm.fit(rain, floc=0)

            rain_sorted = np.sort(rain)
            ccdf = 1 - np.arange(1, len(rain_sorted) + 1) / len(rain_sorted)

            mask = ccdf > 0
            rain_tail = rain_sorted[mask]

            results.append({
                "Year": year,
                "Month": month,
                "Samples": len(rain),
                "Lognormal_sigma": shape,
                "Tail_Size": len(rain_tail)
            })

    return pd.DataFrame(results)


if __name__ == "__main__":
    df = monthly_tail_analysis("path_to_main_folder")
    df.to_csv("monthly_tail_summary.csv", index=False)
